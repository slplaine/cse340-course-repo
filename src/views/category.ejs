<%- include("partials/header") %>

<main>
    <h1><%= title %></h1>

    <h2><%= category.name %></h2>

    <h3>Projects in this Category</h3>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
            </li>
        <% }) %>
    </ul>
</main>

<%- include("partials/footer") %>